<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Your OTP Code</title>
    <style>
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica,
          Arial, sans-serif;
        line-height: 1.4;
        color: #1e293b;
        margin: 0;
        padding: 0;
        background-color: #f1f5f9;
      }
      .container {
        max-width: 400px;
        margin: 20px auto;
        background-color: #ffffff;
        border-radius: 12px;
        padding: 32px 24px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      }
      .header {
        text-align: center;
        margin-bottom: 24px;
      }
      .header h2 {
        margin: 0;
        color: #0f172a;
        font-size: 24px;
        font-weight: 600;
      }
      .greeting {
        font-size: 16px;
        margin-bottom: 16px;
      }
      .greeting strong {
        color: #2563eb;
      }
      .otp-box {
        background-color: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        padding: 20px;
        margin: 24px 0;
        text-align: center;
      }
      .otp-code {
        font-family: 'Courier New', monospace;
        font-size: 40px;
        font-weight: 700;
        letter-spacing: 8px;
        color: #2563eb;
      }
      .expiry {
        background-color: #fee2e2;
        border-left: 4px solid #ef4444;
        padding: 12px 16px;
        margin: 20px 0;
        font-size: 14px;
        color: #991b1b;
        border-radius: 4px;
      }
      .warning {
        font-size: 13px;
        color: #64748b;
        margin-top: 24px;
        padding-top: 16px;
        border-top: 1px solid #e2e8f0;
      }
      .footer {
        text-align: center;
        margin-top: 24px;
        font-size: 12px;
        color: #94a3b8;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h2>🔐 Verification Code</h2>
      </div>

      <div class="greeting">Hello <strong><%= name %></strong>,</div>

      <p style="margin: 0 0 8px 0; color: #334155">
        Your one-time password (OTP) is:
      </p>

      <div class="otp-box">
        <div class="otp-code"><%= otp %></div>
      </div>

      <div class="expiry">
        ⏰ This code will expire in <strong>2 minutes</strong>
      </div>

      <div class="warning">
        ⚠️ Never share this code with anyone. Our team will never ask for this
        code.
      </div>

      <div class="footer">
        <p>If you didn't request this code, please ignore this email.</p>
        <p style="margin-top: 12px">
          &copy; 2024 Your App. All rights reserved.
        </p>
      </div>
    </div>
  </body>
</html>
