<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Payment Receipt</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f6f6f6;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 20px auto;
        background: #ffffff;
        padding: 20px;
        border-radius: 8px;
      }
      .header {
        text-align: center;
      }
      .header h1 {
        margin: 0;
      }
      .section {
        margin-top: 20px;
      }
      .section h3 {
        margin-bottom: 8px;
        border-bottom: 1px solid #ddd;
        padding-bottom: 4px;
      }
      .row {
        display: flex;
        justify-content: space-between;
        margin: 5px 0;
      }
      .total {
        font-weight: bold;
        font-size: 16px;
      }
      .footer {
        margin-top: 30px;
        font-size: 12px;
        text-align: center;
        color: #777;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <!-- Header -->
      <div class="header">
        <h1>Payment Receipt</h1>
        <p>Your Learning Platform</p>
      </div>

      <!-- Payment Info -->
      <div class="section">
        <h3>Payment Information</h3>
        <div class="row">
          <span>Payment ID:</span>
          <span><%= paymentId %></span>
        </div>
        <div class="row">
          <span>Transaction ID:</span>
          <span><%= transactionId %></span>
        </div>
        <div class="row">
          <span>Payment Date:</span>
          <span><%= new Date(paymentDate).toLocaleDateString() %></span>
        </div>
      </div>

      <!-- Learner Info -->
      <div class="section">
        <h3>Learner Information</h3>
        <div class="row">
          <span>Name:</span>
          <span><%= learnerName %></span>
        </div>
        <div class="row">
          <span>Email:</span>
          <span><%= learnerEmail %></span>
        </div>
      </div>

      <!-- Course Info -->
      <div class="section">
        <h3>Course Information</h3>
        <div class="row">
          <span>Course Title:</span>
          <span><%= courseTitle %></span>
        </div>
      </div>

      <!-- Payment Summary -->
      <div class="section">
        <h3>Payment Summary</h3>
        <div class="row">
          <span>Course Fee:</span>
          <span><%= amount.toFixed(2) %> BDT</span>
        </div>
        <div class="row total">
          <span>Total:</span>
          <span><%= amount.toFixed(2) %> BDT</span>
        </div>
      </div>

      <!-- Footer -->
      <div class="footer">
        <p>
          Thank you for your purchase. This is an electronically generated
          receipt.
        </p>
        <p>If you have any questions, contact us at support@yourplatform.com</p>
      </div>
    </div>
  </body>
</html>
