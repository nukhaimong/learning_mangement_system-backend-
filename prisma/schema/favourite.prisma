model Favourites {
  id        String   @id @default(ulid())
  createdAt DateTime @default(now())
  deletedAt DateTime @default(now())

  course_id String
  course    Course @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  learner_id String
  learner    Learner @relation(fields: [learner_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([course_id])
  @@index([learner_id])
  @@map("favourites")
}
