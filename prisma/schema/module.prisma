model Module {
  id          String   @id @default(uuid())
  title       String
  order_index Int
  createdAt   DateTime @default(now())
  deletedAt   DateTime @default(now())

  course_id String
  course    Course @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  lectures Lecture[]

  @@index([course_id])
  @@map("module")
}
