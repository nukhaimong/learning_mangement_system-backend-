model Reviews {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  course_id String
  course    Course @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  learner_id String
  learner    Learner @relation(fields: [learner_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([course_id])
  @@index([learner_id])
  @@map("reviews")
}
